#!/bin/bash
# Pre-commit hook: Security check + unit tests before allowing commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# PHASE 1: Security scan for credentials
echo ""
echo "🔒 PHASE 1: Security credential scan..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

SECURITY_FAILED=0

# Files/patterns to block absolutely
BLOCKED_PATTERNS=(
    "\.tfstate$"
    "\.tfstate\.backup$"
    "\.tfstate\.lock\.hcl$"
    "google-service-account\.json$"
    "lambda-function\.zip$"
    "\.env\.local$"
    "\.env\.secret$"
)

# Patterns to warn about (grep regex format)
CREDENTIAL_PATTERNS=(
    "ANTHROPIC_API_KEY[[:space:]]*[=:]"
    "aws_access_key_id"
    "aws_secret_access_key"
    "-----BEGIN.*PRIVATE"
    "-----BEGIN.*RSA"
    "[Aa][Pp][Ii][_-]?[Kk][Ee][Yy][[:space:]]*="
    "[Ss][Ee][Cc][Rr][Ee][Tt][_-]?[Kk][Ee][Yy][[:space:]]*="
)

# Get staged files (exclude hook files and documentation from credential check)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -v "\.githooks\|\.git/hooks\|docs/superpowers\|\.md$" || true)

if [ -n "$STAGED_FILES" ]; then
    # Check for blocked files
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        matches=$(echo "$STAGED_FILES" | grep -E "$pattern" || true)
        if [ -n "$matches" ]; then
            echo -e "${RED}✗ BLOCKED: Sensitive file pattern detected:${NC}"
            echo "$matches" | sed 's/^/  /'
            SECURITY_FAILED=1
        fi
    done

    # Check for credential patterns in staged content
    for pattern in "${CREDENTIAL_PATTERNS[@]}"; do
        matches=$(git diff --cached -- $STAGED_FILES 2>/dev/null | grep -E -- "$pattern" || true)
        if [ -n "$matches" ]; then
            echo -e "${RED}✗ BLOCKED: Credential pattern detected:${NC}"
            # Don't show the actual credential value - just indicate detection
            echo "$matches" | sed 's/^[+]/  +/' | head -1
            SECURITY_FAILED=1
        fi
    done
fi

if [ $SECURITY_FAILED -eq 1 ]; then
    echo ""
    echo -e "${RED}════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}❌ Security check FAILED${NC}"
    echo -e "${RED}════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "Commit blocked: potentially sensitive files detected."
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Security check passed - no credentials detected${NC}"
echo ""

# PHASE 2: Run unit tests
echo "🧪 PHASE 2: Running unit tests..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
xcodebuild -scheme ReceiptVault \
    -destination 'platform=iOS Simulator,name=iPhone 17 Pro' \
    -configuration Debug \
    test 2>&1 | tail -50

if [ $? -ne 0 ]; then
    echo ""
    echo -e "${RED}════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}❌ Tests FAILED${NC}"
    echo -e "${RED}════════════════════════════════════════════════════════${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}✅ All checks passed - commit allowed${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
exit 0
